#!/usr/bin/env bash
set -euo pipefail

if [ $# -eq 0 ]; then
  echo "Usage: logos <project-name>"
  exit 1
fi

PROJECT="$1"

if [ -d "$PROJECT" ]; then
  echo "Error: directory '$PROJECT' already exists."
  exit 1
fi

mkdir -p "$PROJECT"
cd "$PROJECT"

git init -q

cat > agenda.md << 'EOF'
# Research Agenda

## Overview


## Questions


## Goals


## References

EOF

git add .
git commit -q -m "Initialize research project"

echo "Created research project: $PROJECT"
